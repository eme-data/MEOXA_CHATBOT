# === Meoxa Chatbot Configuration ===

# Admin API key for securing the REST API
ADMIN_API_KEY=your-secret-admin-key-here

# Server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Domain name for HTTPS (required for SSL)
DOMAIN=chatbot.example.com

# Email for Let's Encrypt notifications
CERTBOT_EMAIL=admin@example.com

# Note: Telegram tokens and Claude API keys are configured per-tenant
# via the REST API or config/tenants.json
